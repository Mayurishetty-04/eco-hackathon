# Environment Variables — EcoTrack Flutter App
# ================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env to git.
# ================================================

# Base URL of the external API (Node.js or any backend)
# Change this to your deployed URL when ready
API_BASE_URL=http://localhost:5000/api

# App environment
APP_ENV=development

# Feature flags (set to true when feature is ready)
ENABLE_AI_FEATURE=false
ENABLE_MAP_FEATURE=false
